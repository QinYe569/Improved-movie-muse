<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.dao.FavoriteMapper">
    
    <!-- 结果映射（包含关联电影） -->
    <resultMap id="FavoriteResultMap" type="Favorite">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="movieId" column="movie_id"/>
        <result property="createTime" column="create_time"/>
        <!-- 关联电影映射 -->
        <association property="movie" javaType="Movie">
            <id property="id" column="movie_id"/>
            <result property="title" column="title"/>
            <result property="poster" column="poster"/>
            <result property="rating" column="rating"/>
        </association>
    </resultMap>
    
    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        f.id, f.user_id, f.movie_id, f.create_time, m.title, m.poster, m.rating
    </sql>
    
    <!-- 根据 ID 查询收藏 -->
    <select id="findById" parameterType="int" resultMap="FavoriteResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM favorite f
        LEFT JOIN movie m ON f.movie_id = m.id
        WHERE f.id = #{id}
    </select>
    
    <!-- 根据用户 ID 查询收藏 -->
    <select id="findByUserId" parameterType="int" resultMap="FavoriteResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM favorite f
        LEFT JOIN movie m ON f.movie_id = m.id
        WHERE f.user_id = #{userId}
        ORDER BY f.create_time DESC
    </select>
    
    <!-- 检查用户是否已收藏某电影 -->
    <select id="findByUserIdAndMovieId" resultMap="FavoriteResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM favorite f
        LEFT JOIN movie m ON f.movie_id = m.id
        WHERE f.user_id = #{userId} AND f.movie_id = #{movieId}
    </select>
    
    <!-- 插入收藏 -->
    <insert id="insert" parameterType="Favorite" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO favorite (
            user_id, movie_id
        ) VALUES (
            #{userId}, #{movieId}
        )
    </insert>
    
    <!-- 删除收藏 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM favorite WHERE id = #{id}
    </delete>
    
    <!-- 根据用户 ID 和电影 ID 删除收藏 -->
    <delete id="deleteByUserIdAndMovieId">
        DELETE FROM favorite 
        WHERE user_id = #{userId} AND movie_id = #{movieId}
    </delete>
    
    <!-- 获取用户收藏总数 -->
    <select id="countByUserId" parameterType="int" resultType="int">
        SELECT COUNT(*) FROM favorite WHERE user_id = #{userId}
    </select>

    <!-- 获取各电影的收藏数量 -->
    <select id="countByMovie" resultType="java.util.HashMap">
        SELECT
            m.id as movieId,
            m.title as title,
            COUNT(f.id) as favoriteCount
        FROM movie m
        LEFT JOIN favorite f ON m.id = f.movie_id
        GROUP BY m.id, m.title
        ORDER BY favoriteCount DESC
    </select>

</mapper>
