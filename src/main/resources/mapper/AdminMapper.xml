<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.dao.AdminMapper">
    
    <!-- 结果映射 -->
    <resultMap id="AdminResultMap" type="Admin">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="role" column="role"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
    </resultMap>
    
    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        id, username, password, role, status, create_time
    </sql>
    
    <!-- 根据 ID 查询管理员 -->
    <select id="findById" parameterType="int" resultMap="AdminResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM admin
        WHERE id = #{id}
    </select>
    
    <!-- 根据用户名查询管理员 -->
    <select id="findByUsername" parameterType="string" resultMap="AdminResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM admin
        WHERE username = #{username}
    </select>
    
    <!-- 插入管理员 -->
    <insert id="insert" parameterType="Admin" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO admin (
            username, password, role, status
        ) VALUES (
            #{username}, #{password}, #{role}, #{status}
        )
    </insert>
    
    <!-- 更新管理员信息 -->
    <update id="update" parameterType="Admin">
        UPDATE admin
        <set>
            <if test="password != null">password = #{password},</if>
            <if test="role != null">role = #{role},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 删除管理员 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM admin WHERE id = #{id}
    </delete>
    
</mapper>
