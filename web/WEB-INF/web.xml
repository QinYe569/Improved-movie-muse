<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee 
                             https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <!-- ============================================= -->
    <!-- 用户相关 Servlet 配置 -->
    <!-- ============================================= -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>org.example.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/api/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>org.example.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/api/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>org.example.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/api/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>CheckAuthServlet</servlet-name>
        <servlet-class>org.example.servlet.CheckAuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckAuthServlet</servlet-name>
        <url-pattern>/api/check-auth</url-pattern>
    </servlet-mapping>

    <!-- ============================================= -->
    <!-- 电影相关 Servlet 配置 -->
    <!-- ============================================= -->
    <servlet>
        <servlet-name>MovieDetailServlet</servlet-name>
        <servlet-class>org.example.servlet.MovieDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MovieDetailServlet</servlet-name>
        <url-pattern>/api/movie-detail</url-pattern>
    </servlet-mapping>

    <!-- ============================================= -->
    <!-- 评论相关 Servlet 配置 -->
    <!-- ============================================= -->
    <servlet>
        <servlet-name>CommentListServlet</servlet-name>
        <servlet-class>org.example.servlet.CommentListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CommentListServlet</servlet-name>
        <url-pattern>/api/comments</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddCommentServlet</servlet-name>
        <servlet-class>org.example.servlet.AddCommentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddCommentServlet</servlet-name>
        <url-pattern>/api/comment/add</url-pattern>
    </servlet-mapping>

    <!-- ============================================= -->
    <!-- 收藏相关 Servlet 配置 -->
    <!-- ============================================= -->
    <servlet>
        <servlet-name>FavoriteServlet</servlet-name>
        <servlet-class>org.example.servlet.FavoriteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FavoriteServlet</servlet-name>
        <url-pattern>/api/favorite</url-pattern>
    </servlet-mapping>

    <!-- ============================================= -->
    <!-- 管理后台相关 Servlet 配置 -->
    <!-- ============================================= -->
    <servlet>
        <servlet-name>AdminLoginServlet</servlet-name>
        <servlet-class>org.example.servlet.AdminLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminLoginServlet</servlet-name>
        <url-pattern>/admin/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>org.example.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminMovieListServlet</servlet-name>
        <servlet-class>org.example.servlet.AdminMovieListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminMovieListServlet</servlet-name>
        <url-pattern>/admin/movies</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminMovieEditServlet</servlet-name>
        <servlet-class>org.example.servlet.AdminMovieEditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminMovieEditServlet</servlet-name>
        <url-pattern>/admin/movie-edit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminUserListServlet</servlet-name>
        <servlet-class>org.example.servlet.AdminUserListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUserListServlet</servlet-name>
        <url-pattern>/admin/users</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminLogoutServlet</servlet-name>
        <servlet-class>org.example.servlet.AdminLogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminLogoutServlet</servlet-name>
        <url-pattern>/admin/logout</url-pattern>
    </servlet-mapping>

    <!-- ============================================= -->
    <!-- 欢迎页面配置 -->
    <!-- ============================================= -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- ============================================= -->
    <!-- 会话超时配置（30 分钟） -->
    <!-- ============================================= -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

</web-app>
