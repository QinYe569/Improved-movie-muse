<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.dao.SearchHistoryMapper">

    <!-- 结果映射 -->
    <resultMap id="SearchHistoryResultMap" type="SearchHistory">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="keyword" column="keyword"/>
        <result property="searchTime" column="search_time"/>
    </resultMap>

    <!-- 根据用户 ID 查询搜索历史 -->
    <select id="findByUserId" parameterType="int" resultMap="SearchHistoryResultMap">
        SELECT *
        FROM search_history
        WHERE user_id = #{userId}
        ORDER BY search_time DESC
    </select>

    <!-- 插入搜索历史 -->
    <insert id="insert" parameterType="SearchHistory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO search_history (
            user_id, keyword
        ) VALUES (
            #{userId}, #{keyword}
        )
    </insert>

    <!-- 根据 ID 删除搜索历史 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM search_history WHERE id = #{id}
    </delete>

    <!-- 清空某用户的所有搜索历史 -->
    <delete id="clearByUserId" parameterType="int">
        DELETE FROM search_history WHERE user_id = #{userId}
    </delete>

</mapper>
