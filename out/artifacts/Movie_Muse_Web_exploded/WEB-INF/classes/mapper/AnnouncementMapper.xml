<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.dao.AnnouncementMapper">

    <resultMap id="AnnouncementResultMap" type="Announcement">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="publishTime" column="publish_time"/>
        <result property="authorId" column="author_id"/>
        <association property="author" javaType="Admin">
            <id property="id" column="author_id"/>
            <result property="username" column="author_username"/>
        </association>
    </resultMap>

    <select id="findById" parameterType="int" resultMap="AnnouncementResultMap">
        SELECT a.*, ad.username as author_username
        FROM announcement a
        LEFT JOIN admin ad ON a.author_id = ad.id
        WHERE a.id = #{id}
    </select>

    <select id="findAll" resultMap="AnnouncementResultMap">
        SELECT a.*, ad.username as author_username
        FROM announcement a
        LEFT JOIN admin ad ON a.author_id = ad.id
        ORDER BY a.publish_time DESC
    </select>

    <insert id="insert" parameterType="Announcement" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO announcement (title, content, author_id)
        VALUES (#{title}, #{content}, #{authorId})
    </insert>

    <delete id="deleteById" parameterType="int">
        DELETE FROM announcement WHERE id = #{id}
    </delete>

</mapper>