<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.dao.CategoryMapper">
    
    <!-- 结果映射 -->
    <resultMap id="CategoryResultMap" type="Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="icon" column="icon"/>
        <result property="description" column="description"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="status" column="status"/>
    </resultMap>
    
    <!-- 通用查询列 -->
    <sql id="Base_Column_List">
        id, name, icon, description, sort_order, status
    </sql>
    
    <!-- 根据 ID 查询分类 -->
    <select id="findById" parameterType="int" resultMap="CategoryResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM category
        WHERE id = #{id}
    </select>
    
    <!-- 根据名称查询分类 -->
    <select id="findByName" parameterType="string" resultMap="CategoryResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM category
        WHERE name = #{name}
    </select>
    
    <!-- 查询所有分类 -->
    <select id="findAll" resultMap="CategoryResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM category
        WHERE status = 1
        ORDER BY sort_order ASC
    </select>

    <!-- 查询所有分类（管理后台使用，包含禁用状态） -->
    <select id="findAllForAdmin" resultMap="CategoryResultMap">
        SELECT
            <include refid="Base_Column_List"/>
        FROM category
        ORDER BY sort_order ASC, id ASC
    </select>

    <!-- 插入分类 -->
    <insert id="insert" parameterType="Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (
            name, icon, description, sort_order, status
        ) VALUES (
            #{name}, #{icon}, #{description}, #{sortOrder}, #{status}
        )
    </insert>
    
    <!-- 更新分类 -->
    <update id="update" parameterType="Category">
        UPDATE category
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="icon != null">icon = #{icon},</if>
            <if test="description != null">description = #{description},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <!-- 删除分类 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM category WHERE id = #{id}
    </delete>
    
</mapper>
